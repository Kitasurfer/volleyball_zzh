# Environment variables (placeholders)

## Frontend (Vite)
VITE_SUPABASE_URL=https://<YOUR_SUPABASE_PROJECT>.supabase.co
VITE_SUPABASE_FUNCTIONS_URL=https://<YOUR_SUPABASE_PROJECT>.functions.supabase.co
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

## Supabase edge functions
SUPABASE_URL=https://<YOUR_SUPABASE_PROJECT>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
VLW_API_KEY=<YOUR_VLW_API_KEY> # for league-results

## Qdrant
QDRANT_URL=https://<YOUR_QDRANT_CLUSTER>.cloud.qdrant.io
QDRANT_API_KEY=<YOUR_QDRANT_API_KEY>
QDRANT_COLLECTION=content_vectors
INGEST_BATCH_SIZE=5

## OpenAI embeddings
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_EMBED_MODEL=text-embedding-3-small

## Cerebras chat
CEREBRAS_API_KEY=<YOUR_CEREBRAS_API_KEY>
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_CHAT_MODEL=llama3.1-8b
CEREBRAS_EMBED_MODEL=embedding-english-v1

## Docling service
DOCLING_SERVICE_URL=https://<YOUR_DOCLING_SERVICE_URL>

## Chatbot tuning
CHAT_MAX_OUTPUT_TOKENS=1200
CHAT_MIN_SCORE=0.25
